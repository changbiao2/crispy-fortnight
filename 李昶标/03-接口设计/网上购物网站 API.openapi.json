{
  "openapi": "3.0.1",
  "info": {
    "title": "网上购物网站 API",
    "description": "## 概述\n网上购物网站的商品展示、查询、购物车模块 RESTful API 接口文档。\n\n## 模块说明\n- **商品模块**：商品列表、商品详情、商品搜索\n- **购物车模块**：购物车查看、添加、修改、删除、清空\n\n## 认证方式\n购物车相关接口需要在请求头中携带 `Authorization: Bearer {token}`\n\n## 统一响应格式\n```json\n{\n  \"code\": 200,\n  \"message\": \"操作成功\",\n  \"data\": { ... }\n}\n```\n\n## 状态码说明\n| 状态码 | 说明 |\n|--------|------|\n| 200 | 操作成功 |\n| 400 | 请求参数错误 |\n| 401 | 未登录或 token 过期 |\n| 403 | 无权限 |\n| 404 | 资源不存在 |\n| 500 | 服务器内部错误 |\n",
    "version": "1.0.0",
    "contact": {
      "name": "开发团队",
      "email": "team@shopping.com"
    }
  },
  "tags": [
    {
      "name": "商品管理"
    },
    {
      "name": "购物车管理"
    }
  ],
  "paths": {
    "/api/products": {
      "get": {
        "summary": "获取商品列表",
        "deprecated": false,
        "description": "分页获取商品列表，支持按分类筛选、关键词搜索、价格区间过滤、排序等功能。\n不需要登录即可访问。\n",
        "operationId": "getProductList",
        "tags": [
          "商品管理"
        ],
        "parameters": [
          {
            "name": "categoryId",
            "in": "query",
            "description": "分类ID，传入则只返回该分类下的商品",
            "required": false,
            "example": "CAT004",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "description": "搜索关键词，模糊匹配商品名称和描述",
            "required": false,
            "example": "iPhone",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "minPrice",
            "in": "query",
            "description": "最低价格（包含）",
            "required": false,
            "example": 100,
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": 0
            }
          },
          {
            "name": "maxPrice",
            "in": "query",
            "description": "最高价格（包含）",
            "required": false,
            "example": 10000,
            "schema": {
              "type": "number",
              "format": "double",
              "minimum": 0
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "排序字段：\n- `price` 按价格排序\n- `sales` 按销量排序\n- `createTime` 按上架时间排序\n",
            "required": false,
            "example": "price",
            "schema": {
              "type": "string",
              "enum": [
                "price",
                "sales",
                "createTime"
              ],
              "default": "createTime"
            }
          },
          {
            "name": "sortOrder",
            "in": "query",
            "description": "排序方式：\n- `asc` 升序\n- `desc` 降序\n",
            "required": false,
            "example": "asc",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "页码，从1开始",
            "required": false,
            "example": 1,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "每页数量，最大50",
            "required": false,
            "example": 10,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/ProductPageResult"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 200,
                  "message": "获取成功",
                  "data": {
                    "total": 100,
                    "page": 1,
                    "pageSize": 10,
                    "totalPages": 10,
                    "list": [
                      {
                        "productId": "PROD001",
                        "name": "iPhone 15 Pro",
                        "categoryId": "CAT004",
                        "categoryName": "手机",
                        "price": 8999,
                        "stock": 100,
                        "description": "Apple iPhone 15 Pro 256GB",
                        "imageUrl": "/images/iphone15.jpg",
                        "status": 1,
                        "createTime": "2026-01-15 10:30:00"
                      },
                      {
                        "productId": "PROD002",
                        "name": "MacBook Pro 14",
                        "categoryId": "CAT005",
                        "categoryName": "电脑",
                        "price": 14999,
                        "stock": 50,
                        "description": "Apple MacBook Pro 14英寸 M3芯片",
                        "imageUrl": "/images/macbook14.jpg",
                        "status": 1,
                        "createTime": "2026-01-10 09:00:00"
                      }
                    ]
                  }
                }
              }
            },
            "headers": {}
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 400,
                  "message": "价格区间参数错误，minPrice不能大于maxPrice",
                  "data": null
                }
              }
            },
            "headers": {}
          },
          "500": {
            "description": "服务器内部错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 500,
                  "message": "服务器内部错误",
                  "data": null
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/api/products/{productId}": {
      "get": {
        "summary": "获取商品详情",
        "deprecated": false,
        "description": "根据商品ID获取商品的完整详细信息，包括商品基本信息和图片列表。\n不需要登录即可访问。\n",
        "operationId": "getProductDetail",
        "tags": [
          "商品管理"
        ],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "description": "商品ID",
            "required": true,
            "example": "PROD001",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/ProductDetail"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 200,
                  "message": "获取成功",
                  "data": {
                    "productId": "PROD001",
                    "name": "iPhone 15 Pro",
                    "categoryId": "CAT004",
                    "categoryName": "手机",
                    "price": 8999,
                    "stock": 100,
                    "description": "Apple iPhone 15 Pro 256GB 原色钛金属，A17 Pro芯片，4800万像素主摄",
                    "imageUrl": "/images/iphone15.jpg",
                    "images": [
                      {
                        "imageId": "IMG001",
                        "imageUrl": "/images/iphone15_1.jpg",
                        "sortOrder": 1
                      },
                      {
                        "imageId": "IMG002",
                        "imageUrl": "/images/iphone15_2.jpg",
                        "sortOrder": 2
                      },
                      {
                        "imageId": "IMG003",
                        "imageUrl": "/images/iphone15_3.jpg",
                        "sortOrder": 3
                      }
                    ],
                    "status": 1,
                    "createTime": "2026-01-15 10:30:00",
                    "updateTime": "2026-02-20 14:20:00"
                  }
                }
              }
            },
            "headers": {}
          },
          "404": {
            "description": "商品不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 404,
                  "message": "商品不存在",
                  "data": null
                }
              }
            },
            "headers": {}
          },
          "500": {
            "description": "服务器内部错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 500,
                  "message": "服务器内部错误",
                  "data": null
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/api/products/search": {
      "get": {
        "summary": "搜索商品",
        "deprecated": false,
        "description": "根据关键词搜索商品，模糊匹配商品名称和描述。\n不需要登录即可访问。\n",
        "operationId": "searchProducts",
        "tags": [
          "商品管理"
        ],
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "description": "搜索关键词（必填）",
            "required": true,
            "example": "华为手机",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 50
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "页码，从1开始",
            "required": false,
            "example": 1,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "每页数量，最大50",
            "required": false,
            "example": 10,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "搜索成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/ProductPageResult"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 200,
                  "message": "搜索成功",
                  "data": {
                    "total": 2,
                    "page": 1,
                    "pageSize": 10,
                    "totalPages": 1,
                    "list": [
                      {
                        "productId": "PROD004",
                        "name": "华为 Mate 60 Pro",
                        "categoryId": "CAT004",
                        "categoryName": "手机",
                        "price": 6999,
                        "stock": 80,
                        "description": "华为 Mate 60 Pro 512GB 雅丹黑",
                        "imageUrl": "/images/mate60.jpg",
                        "status": 1,
                        "createTime": "2026-01-12 15:00:00"
                      }
                    ]
                  }
                }
              }
            },
            "headers": {}
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 400,
                  "message": "搜索关键词不能为空",
                  "data": null
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/api/cart": {
      "get": {
        "summary": "获取购物车列表",
        "deprecated": false,
        "description": "获取当前登录用户的购物车商品列表，包含每个商品的小计和购物车总价。\n**需要登录**。\n",
        "operationId": "getCartList",
        "tags": [
          "购物车管理"
        ],
        "parameters": [],
        "responses": {
          "200": {
            "description": "获取成功",
