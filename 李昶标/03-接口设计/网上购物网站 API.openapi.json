      "post": {
        "summary": "添加商品到购物车",
        "deprecated": false,
        "description": "将指定商品添加到当前用户的购物车中。\n- 如果购物车中已有该商品，则累加数量\n- 添加前会检查商品库存是否充足\n- **需要登录**\n",
        "operationId": "addToCart",
        "tags": [
          "购物车管理"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddCartRequest"
              },
              "example": {
                "productId": "PROD001",
                "quantity": 1
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "添加成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/CartItem"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 200,
                  "message": "添加成功",
                  "data": {
                    "cartId": "CART008",
                    "productId": "PROD001",
                    "productName": "iPhone 15 Pro",
                    "productImage": "/images/iphone15.jpg",
                    "price": 8999,
                    "quantity": 1,
                    "subtotal": 8999,
                    "stock": 100,
                    "status": 1
                  }
                }
              }
            },
            "headers": {}
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "2": {
                    "summary": "参数缺失",
                    "value": {
                      "code": 400,
                      "message": "商品ID不能为空",
                      "data": null
                    }
                  },
                  "3": {
                    "summary": "数量错误",
                    "value": {
                      "code": 400,
                      "message": "商品数量必须大于0",
                      "data": null
                    }
                  },
                  "4": {
                    "summary": "库存不足",
                    "value": {
                      "code": 400,
                      "message": "商品库存不足，当前库存：5",
                      "data": null
                    }
                  }
                }
              }
            },
            "headers": {}
          },
          "401": {
            "description": "未登录",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 401,
                  "message": "请先登录",
                  "data": null
                }
              }
            },
            "headers": {}
          },
          "404": {
            "description": "商品不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 404,
                  "message": "商品不存在或已下架",
                  "data": null
                }
              }
            },
            "headers": {}
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/api/cart/{cartId}": {
      "put": {
        "summary": "修改购物车商品数量",
        "deprecated": false,
        "description": "修改购物车中指定商品的数量。\n- 数量必须大于0\n- 修改前会检查商品库存是否充足\n- 修改后自动重新计算小计金额\n- **需要登录**\n",
        "operationId": "updateCartQuantity",
        "tags": [
          "购物车管理"
        ],
        "parameters": [
          {
            "name": "cartId",
            "in": "path",
            "description": "购物车项ID",
            "required": true,
            "example": "CART001",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateCartRequest"
              },
              "example": {
                "quantity": 3
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "修改成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/CartItem"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 200,
                  "message": "修改成功",
                  "data": {
                    "cartId": "CART001",
                    "productId": "PROD001",
                    "productName": "iPhone 15 Pro",
                    "productImage": "/images/iphone15.jpg",
                    "price": 8999,
                    "quantity": 3,
