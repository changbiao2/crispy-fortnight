                    }
                  }
                }
              }
            },
            "headers": {}
          },
          "401": {
            "description": "未登录",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 401,
                  "message": "请先登录",
                  "data": null
                }
              }
            },
            "headers": {}
          },
          "404": {
            "description": "购物车项不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 404,
                  "message": "购物车中未找到该商品",
                  "data": null
                }
              }
            },
            "headers": {}
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      },
      "delete": {
        "summary": "删除购物车商品",
        "deprecated": false,
        "description": "从购物车中删除指定的商品项。\n- 删除后自动重新计算购物车总价\n- **需要登录**\n",
        "operationId": "deleteCartItem",
        "tags": [
          "购物车管理"
